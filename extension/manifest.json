{
  "manifest_version": 3,
  "name": "Colosseum Relay",
  "version": "0.1.0",
  "description": "Automates prompt relay between Colosseum and claude.ai / chatgpt.com",
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*"],
      "js": ["content/bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/claude.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content/gpt.js"],
      "run_at": "document_idle"
    }
  ]
}
